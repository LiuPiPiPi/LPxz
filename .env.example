API_PORT=8090
VIEW_PORT=8080
CMS_PORT=3000

FLASK_ENV=development
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=8090
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too
SQLITE_DATABASE=instance/lpxz.sqlite3
SQLITE_BACKUP_DIR=backups
ENABLE_SCHEDULER=true
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

VUE_APP_API_BASE_URL=/api/
VUE_APP_NAME=prod
VUE_APP_DEFAULT_LOGIN_USERNAME=

REACT_APP_API_BASE_URL=/api/admin/
REACT_APP_SITE_URL=https://lpxz.work
REACT_APP_ROUTER_BASENAME=/cms

# Local frontend dev servers do not have the production Nginx /api proxy.
# lpxz_view uses npm run serve -> vue-cli-service serve --mode development, so put this in lpxz_view/.env.development:
# VUE_APP_API_BASE_URL=http://lpxz.work:8090/
# lpxz_cms uses npm start, so put this in lpxz_cms/.env.development:
# REACT_APP_API_BASE_URL=http://lpxz.work:8090/admin/
# REACT_APP_ROUTER_BASENAME=
